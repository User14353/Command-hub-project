local function getSize()
    local vp = cam.ViewportSize
    local w  = math.clamp(math.floor(vp.X * 0.38), 380, 620)
    local h  = math.clamp(math.floor(vp.Y * 0.75), 460, 720)
    local x  = math.floor(vp.X * 0.5 - w * 0.5)
    local y  = math.floor(vp.Y * 0.5 - h * 0.5)
    return w, h, x, y
end

