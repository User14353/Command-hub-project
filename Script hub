local function notify(title, body, dur)
    StarterGui:SetCore("SendNotification", {
        Title    = title,
        Text     = body,
        Duration = dur or 3,
    })
end

-- Send a chat message
local function sendChat(msg)
    pcall(function()
        game:GetService("ReplicatedStorage")
            .DefaultChatSystemChatEvents
            .SayMessageRequest:FireServer(msg, "All")
    end)
end

-- Load and execute a script from a URL
local function loadScript(url, name)
    local ok, result = pcall(function()
        return game:HttpGet(url)
    end)
    if not ok or not result then
        notify("Hub Error", "Failed to fetch: "..name, 5)
        return
    end
    local fn, err = loadstring(result)
    if not fn then
        notify("Hub Error", "Syntax error in "..name..": "..(err or "?"), 5)
        return
    end
    local ok2, err2 = pcall(fn)
    if not ok2 then
        notify("Hub Error", "Runtime error in "..name..": "..(tostring(err2):sub(1,60)), 5)
    end
end

-- Check if the current game is owned by the rig-loader group
local function isRigLoaderGame()
    local ok, info = pcall(function()
        return MarketplaceService:GetProductInfo(game.PlaceId)
    end)
    -- GetProductInfo doesn't give group ownership; use game.CreatorId + CreatorType
    if game.CreatorType == Enum.CreatorType.Group then
        return game.CreatorId == RIG_LOADER_GROUP_ID
    end
    return false
end

local RIG_GAME = isRigLoaderGame()

