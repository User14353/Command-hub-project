--  BUILD SCRIPT CARDS
--  Each card auto-sizes and contains:
--    • Script name + description
--    • [ Load Script ] button
--    • [ Load Rig ]    button  (only if rigCmd exists AND RIG_GAME is true)
-- ════════════════════════════════════════════════════════════════════════════

local function buildCards()
    -- Clear
    for _, ch in ipairs(scroll:GetChildren()) do
        if ch:IsA("Frame") then ch:Destroy() end
    end

    for idx, script in ipairs(SCRIPTS) do
        --[[
            Card height logic:
              • Base card = 70px  (name + desc + load button)
              • If rig button is shown: +36px
        --]]
        local showRig = RIG_GAME and (script.rigCmd ~= nil)
        local CARD_H  = showRig and 106 or 72

        local card = mkF(scroll, TH.Card,
                         UDim2.new(1,0,0,CARD_H), UDim2.new(0,0,0,0),
                         "Card_"..idx, 8, 2)
        card.LayoutOrder = idx
        stroke(card, TH.Border, 1)

        -- Hover tint
        card.MouseEnter:Connect(function()
            TweenService:Create(card, TweenInfo.new(0.1),
                {BackgroundColor3=TH.CardHov}):Play()
        end)
        card.MouseLeave:Connect(function()
            TweenService:Create(card, TweenInfo.new(0.1),
                {BackgroundColor3=TH.Card}):Play()
        end)

        -- Index badge
        local numBadge = mkF(card, TH.AccentLo,
                             UDim2.new(0,26,0,26), UDim2.new(0,10,0,10),
                             "Num", 5, 3)
        mkL(numBadge, tostring(idx), TH.Accent,
            Enum.Font.GothamBold, 12,
            UDim2.new(1,0,1,0), UDim2.new(0,0,0,0),
            Enum.TextXAlignment.Center, "NumL", 4)

        -- Script name
        mkL(card, script.name, TH.TextPri,
            Enum.Font.GothamBold, 14,
            UDim2.new(1,-170,0,22), UDim2.new(0,44,0,8),
            nil, "Name", 3)

        -- Description
        mkL(card, script.desc or "", TH.TextSec,
            Enum.Font.Gotham, 11,
            UDim2.new(1,-170,0,18), UDim2.new(0,44,0,30),
            nil, "Desc", 3, true)

        -- ── Load Script button ────────────────────────────────────────────────
        local loadBtn = mkB(card,
                            "▶  Load Script",
                            TH.AccentLo, TH.AccentHi,
                            Enum.Font.GothamBold, 12,
                            UDim2.new(0,110,0,28), UDim2.new(1,-124,0,10),
                            "LoadBtn", 6, 3, TH.Accent)

        loadBtn.MouseButton1Click:Connect(function()
            notify("Hub", "Loading "..script.name.."…")
            loadBtn.Text = "Loading…"
            loadBtn.TextColor3 = TH.TextSec
            task.spawn(function()
                loadScript(script.url, script.name)
                task.wait(2)
                loadBtn.Text       = "▶  Load Script"
                loadBtn.TextColor3 = TH.AccentHi
            end)
        end)

        -- ── Rig Loader button (conditional) ───────────────────────────────────
        if showRig then
            -- Divider line
            local div = mkF(card, TH.Border,
                            UDim2.new(1,-20,0,1), UDim2.new(0,10,0,70),
                            "Div", 0, 3)

            -- Rig label
            mkL(card, "⚙ Rig Loader", TH.Rig,
                Enum.Font.GothamBold, 11,
                UDim2.new(0,80,0,22), UDim2.new(0,10,0,74),
                nil, "RigLabel", 3)

            -- Rig description
            mkL(card,
                "Sends: -gh "..script.rigCmd.."  then  -sh",
                TH.TextDis, Enum.Font.Code, 10,
                UDim2.new(1,-120,0,22), UDim2.new(0,92,0,74),
                nil, "RigDesc", 3)

            -- Rig button
            local rigBtn = mkB(card,
                               "⚙  Load Rig",
                               TH.RigLo, TH.Rig,
                               Enum.Font.GothamBold, 12,
                               UDim2.new(0,100,0,22), UDim2.new(1,-114,0,76),
                               "RigBtn", 6, 3, TH.Rig)
            stroke(rigBtn, TH.Rig, 1)

            rigBtn.MouseButton1Click:Connect(function()
                -- Send  -gh <rigCmd>
                sendChat("-gh " .. script.rigCmd)
                notify("Rig Loader",
                       ("Sent: -gh %s\nSending -sh in %.1fs…")
                           :format(script.rigCmd, RIG_CMD_DELAY), 3)

                -- Send  -sh  after delay
                task.delay(RIG_CMD_DELAY, function()
                    sendChat("-sh")
                end)

                -- Visual feedback
                rigBtn.Text       = "Sent!"
                rigBtn.TextColor3 = TH.Green
                task.delay(2, function()
                    rigBtn.Text       = "⚙  Load Rig"
                    rigBtn.TextColor3 = TH.Rig
                end)
            end)
        end
    end
end

